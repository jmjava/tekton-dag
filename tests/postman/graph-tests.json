{
  "info": {
    "name": "M9 – Test-Trace Graph API",
    "_postman_id": "m9-graph-tests-001",
    "description": "Tests for the orchestrator graph/test-plan endpoints (Milestone 9)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    }
  ],
  "item": [
    {
      "name": "Health check",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/healthz"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
              "pm.test('Healthy', function() { pm.expect(pm.response.json().status).to.eql('ok'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Graph stats (empty before ingest)",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/graph/stats"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
              "var json = pm.response.json();",
              "pm.test('Has services count', function() { pm.expect(json).to.have.property('services'); });",
              "pm.test('Has tests count', function() { pm.expect(json).to.have.property('tests'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Ingest mock traces",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/api/graph/ingest",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"traces\":[{\"trace_id\":\"aaa111\",\"test_id\":\"e2e/fe-smoke\",\"test_type\":\"e2e\",\"spans\":[{\"service\":\"demo-fe\",\"resource\":\"GET /\",\"span_id\":\"s1\"},{\"service\":\"release-lifecycle-demo\",\"resource\":\"GET /api/health\",\"span_id\":\"s2\"},{\"service\":\"demo-api\",\"resource\":\"GET /api/status\",\"span_id\":\"s3\"}]},{\"trace_id\":\"aaa222\",\"test_id\":\"e2e/fe-checkout-flow\",\"test_type\":\"e2e\",\"spans\":[{\"service\":\"demo-fe\",\"resource\":\"POST /checkout\",\"span_id\":\"s4\"},{\"service\":\"release-lifecycle-demo\",\"resource\":\"POST /api/orders\",\"span_id\":\"s5\"},{\"service\":\"demo-api\",\"resource\":\"POST /api/orders/create\",\"span_id\":\"s6\"}]},{\"trace_id\":\"aaa333\",\"test_id\":\"e2e/bff-integration\",\"test_type\":\"e2e\",\"spans\":[{\"service\":\"release-lifecycle-demo\",\"resource\":\"GET /api/products\",\"span_id\":\"s7\"},{\"service\":\"demo-api\",\"resource\":\"GET /api/products/list\",\"span_id\":\"s8\"}]},{\"trace_id\":\"bbb111\",\"test_id\":\"individual/fe-unit-api\",\"test_type\":\"individual\",\"spans\":[{\"service\":\"demo-fe\",\"resource\":\"GET /api/config\",\"span_id\":\"s9\"}]},{\"trace_id\":\"bbb444\",\"test_id\":\"individual/api-crud\",\"test_type\":\"individual\",\"spans\":[{\"service\":\"demo-api\",\"resource\":\"GET /api/items\",\"span_id\":\"s13\"}]},{\"trace_id\":\"bbb555\",\"test_id\":\"individual/api-validation\",\"test_type\":\"individual\",\"spans\":[{\"service\":\"demo-api\",\"resource\":\"POST /api/items/validate\",\"span_id\":\"s14\"}]}]}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
              "var json = pm.response.json();",
              "pm.test('Status is ingested', function() { pm.expect(json.status).to.eql('ingested'); });",
              "pm.test('Traces count > 0', function() { pm.expect(json.traces).to.be.above(0); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Graph stats (after ingest)",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/graph/stats"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
              "var json = pm.response.json();",
              "pm.test('Services > 0', function() { pm.expect(json.services).to.be.above(0); });",
              "pm.test('Tests > 0', function() { pm.expect(json.tests).to.be.above(0); });",
              "pm.test('Touches > 0', function() { pm.expect(json.touches_edges).to.be.above(0); });",
              "pm.test('Has 3 services', function() { pm.expect(json.services).to.eql(3); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Test plan: demo-fe (mapped)",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/test-plan?app=demo-fe"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
              "var json = pm.response.json();",
              "pm.test('Has tests', function() { pm.expect(json.tests.length).to.be.above(0); });",
              "pm.test('Unmapped area empty', function() { pm.expect(json.unmapped_area).to.eql(''); });",
              "var ids = json.tests.map(t => t.id);",
              "pm.test('Contains e2e/fe-smoke', function() { pm.expect(ids).to.include('e2e/fe-smoke'); });",
              "pm.test('Contains e2e/fe-checkout-flow', function() { pm.expect(ids).to.include('e2e/fe-checkout-flow'); });",
              "pm.test('Contains individual/fe-unit-api', function() { pm.expect(ids).to.include('individual/fe-unit-api'); });",
              "pm.test('E2e tests first', function() { pm.expect(json.tests[0].type).to.eql('e2e'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Test plan: demo-api (mapped)",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/test-plan?app=demo-api"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
              "var json = pm.response.json();",
              "pm.test('Has tests', function() { pm.expect(json.tests.length).to.be.above(0); });",
              "pm.test('Unmapped area empty', function() { pm.expect(json.unmapped_area).to.eql(''); });",
              "var ids = json.tests.map(t => t.id);",
              "pm.test('Contains e2e/fe-smoke', function() { pm.expect(ids).to.include('e2e/fe-smoke'); });",
              "pm.test('Contains individual/api-crud', function() { pm.expect(ids).to.include('individual/api-crud'); });",
              "pm.test('Contains individual/api-validation', function() { pm.expect(ids).to.include('individual/api-validation'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Test plan: new-service (unmapped)",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/test-plan?app=new-service"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
              "var json = pm.response.json();",
              "pm.test('No tests', function() { pm.expect(json.tests.length).to.eql(0); });",
              "pm.test('Unmapped area set', function() { pm.expect(json.unmapped_area).to.eql('new-service'); });",
              "pm.test('Has message', function() { pm.expect(json.message).to.include('needs tests'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Test plan: missing app param",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/test-plan"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400', function() { pm.response.to.have.status(400); });",
              "pm.test('Error message', function() { pm.expect(pm.response.json().error).to.include('app parameter'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Test plan: with radius param",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/test-plan?app=demo-fe&radius=1"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
              "pm.test('Has tests', function() { pm.expect(pm.response.json().tests.length).to.be.above(0); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Ingest bad request (no traces or fixture_file)",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/api/graph/ingest",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"foo\": \"bar\"}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400', function() { pm.response.to.have.status(400); });",
              "pm.test('Error message', function() { pm.expect(pm.response.json().error).to.include('provide'); });"
            ]
          }
        }
      ]
    }
  ]
}
