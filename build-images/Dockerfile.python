# Python build image. Task script only needs jq to parse JSON; Python/pip already in image.
# Build variants:
#   docker build --build-arg PYTHON_VERSION=3.10 -t ...:python310 -f Dockerfile.python .
#   docker build --build-arg PYTHON_VERSION=3.11 -t ...:python311 -f Dockerfile.python .
ARG PYTHON_VERSION=3.12
FROM python:${PYTHON_VERSION}-slim
RUN apt-get update -qq && apt-get install -y -qq --no-install-recommends jq \
    && rm -rf /var/lib/apt/lists/*
RUN python3 --version && pip3 --version
