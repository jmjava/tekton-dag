{
  "name": "tekton-dag/baggage-middleware",
  "description": "Role-aware W3C baggage / x-dev-session middleware for PHP (PSR-15 + Guzzle)",
  "type": "library",
  "require": {
    "php": ">=8.3"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "guzzlehttp/guzzle": "^7.0"
  },
  "autoload": {
    "psr-4": {
      "TektonDag\\Baggage\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "TektonDag\\Baggage\\Tests\\": "tests/"
    }
  },
  "license": "MIT"
}
